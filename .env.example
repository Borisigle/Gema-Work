# Environment Variables for Dance Studio App
# Copy this file to .env.local and fill in your values

# ─── AUTH SECRET ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# ─── TEACHER CREDENTIALS ───────────────────────────────────────────────────────
# Format: username:password (hardcoded, change before deploy)
TEACHER_CAMI_USER=cami
TEACHER_CAMI_PASS=cami2026

TEACHER_ANI_USER=ani
TEACHER_ANI_PASS=ani2026

TEACHER_NASYA_USER=nasya
TEACHER_NASYA_PASS=nasya2026

TEACHER_LULU_USER=lulu
TEACHER_LULU_PASS=lulu2026

TEACHER_LUCAS_USER=lucas
TEACHER_LUCAS_PASS=lucas2026

TEACHER_MARIAN_USER=marian
TEACHER_MARIAN_PASS=marian2026

# ─── GOOGLE SHEETS ─────────────────────────────────────────────────────────────
# Your Google Sheet ID (from the URL: sheets.google.com/d/SPREADSHEET_ID/edit)
GOOGLE_SHEET_ID=your-spreadsheet-id-here

# Service Account credentials (paste the full JSON as a single line)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"
